{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Image Slot",
  "type": "object",
  "required": [
    "slot_id",
    "page_path",
    "slot_key",
    "usage",
    "priority_level",
    "anchor_text",
    "source_context",
    "purpose",
    "audience_hint",
    "aspect_ratio",
    "recommended_size",
    "alt_text",
    "status",
    "ad_proximity_risk"
  ],
  "properties": {
    "slot_id": {"type": "string"},
    "page_path": {"type": "string"},
    "slot_key": {"type": "string"},
    "usage": {"type": "string", "enum": ["hero", "inline"]},
    "priority_level": {"type": "string", "enum": ["CRITICAL", "IMPORTANT", "LATER"]},
    "anchor_text": {"type": "string"},
    "anchor_selector": {"type": "string"},
    "anchor_index": {"type": "number"},
    "insertion_mode": {"type": "string"},
    "source_context": {"type": "string"},
    "purpose": {"type": "string"},
    "audience_hint": {"type": "string"},
    "aspect_ratio": {"type": "string"},
    "recommended_size": {"type": "string"},
    "alt_text": {"type": "string"},
    "status": {"type": "string"},
    "ad_proximity_risk": {"type": "string", "enum": ["low", "med", "high"]},
    "risk_score": {"type": "number"},
    "risk_factors": {"type": "array", "items": {"type": "string"}},
    "constraints": {"type": "object"},
    "prompt": {"type": "string"},
    "super_prompt": {"type": "string"},
    "technical_constraints": {"type": "string"},
    "realism_profile": {"type": "string"},
    "refined_at": {"type": "string"},
    "discovered_at": {"type": "string"},
    "updated_at": {"type": "string"}
  },
  "additionalProperties": true
}
