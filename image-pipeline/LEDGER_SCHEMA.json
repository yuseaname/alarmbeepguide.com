{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Image Ledger",
  "type": "object",
  "required": ["summary", "items"],
  "properties": {
    "summary": {
      "type": "object",
      "properties": {
        "total_slots": {"type": "integer"},
        "placed": {"type": "integer"},
        "generated_ready": {"type": "integer"},
        "needs_generation": {"type": "integer"},
        "stale_prompt_changed": {"type": "integer"},
        "failed_last_run": {"type": "integer"},
        "locked": {"type": "integer"}
      }
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "slot_id": {"type": "string"},
          "status": {"type": "string"},
          "page_path": {"type": "string"},
          "usage": {"type": "string"},
          "prompt_hash": {"type": "string"}
        }
      }
    }
  }
}
